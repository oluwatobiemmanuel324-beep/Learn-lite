# Learn Lite Backend Environment Variables
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env with real API keys to version control

# ========================================
# Database Configuration
# ========================================
DATABASE_URL="file:./dev.db"
# For PostgreSQL in production: postgresql://user:password@localhost:5432/learn_lite

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET="your_super_secret_jwt_key_here_change_in_production"
# Generate a secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ========================================
# Paystack Payment Integration
# ========================================
# ⚠️  CRITICAL: Keys must NOT have brackets [] or quotes ""
# ✅ Correct:   PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
# ❌ Wrong:     PAYSTACK_PUBLIC_KEY=[pk_test_xxxxx]
# ❌ Wrong:     PAYSTACK_PUBLIC_KEY="pk_test_xxxxx"

PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
# Get from: https://dashboard.paystack.com/#/settings/developer
# Production: Use pk_live_* keys in production

PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
# Get from: https://dashboard.paystack.com/#/settings/developer
# Production: Use sk_live_* keys in production
# ⚠️  WARNING: Never commit this key to version control!
# Use .env (in .gitignore) for actual keys

# ========================================
# Application Configuration
# ========================================
NODE_ENV="development"
# Options: development, production

PORT="4000"
# Server port - must match FRONTEND_ORIGIN

FRONTEND_ORIGIN="http://localhost:5173"
# Frontend URL for CORS - update in production

# ========================================
# Optional: Additional Payment Config
# ========================================
# Payment amounts in kobo (1 naira = 100 kobo)
FUEL_PRICE_KOBO="50000"
# Number of fuel units per purchase
FUEL_PER_PURCHASE="100"
