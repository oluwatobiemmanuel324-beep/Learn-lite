{
  "name": "learn-lite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite --port 5173",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev": "vite --port 5173",
    "build": "vite build",
    "prisma:generate": "npx prisma generate --schema server/prisma/schema.prisma",
    "prisma:migrate:dev": "npx prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:migrate:deploy": "npx prisma migrate deploy --schema server/prisma/schema.prisma",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "framer-motion": "^11.11.1",
    "lucide-react": "^0.474.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma"
  }
}
